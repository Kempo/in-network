# Postgres (Docker)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=in_network
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/in_network

# LLM (BYOK) — fill ANTHROPIC_API_KEY in your local .env, leave others unless used
ANTHROPIC_API_KEY=
LLM_PROVIDER=anthropic
LLM_MODEL=claude-sonnet-4-6

# Services
API_PORT=3000
AGENT_PORT=8000
AGENT_URL=http://localhost:8000
API_URL=http://localhost:3000
