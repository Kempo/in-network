# syntax=docker/dockerfile:1
FROM mcr.microsoft.com/playwright/python:v1.60.0-noble
WORKDIR /app

RUN pip install --no-cache-dir uv

# Install Python deps into an in-image venv from the lockfile.
COPY pyproject.toml uv.lock ./
RUN uv sync --frozen --no-install-project

# Ensure the venv's Playwright has a matching Chromium (system libs come from the base image).
RUN uv run playwright install chromium

# Copy source so the image runs standalone; in dev, Compose bind-mounts over /app.
COPY . .

EXPOSE 8000
CMD ["uv", "run", "--no-sync", "uvicorn", "app.main:app", "--reload", "--reload-dir", "app", "--host", "0.0.0.0", "--port", "8000", "--log-config", "log_config.json"]
