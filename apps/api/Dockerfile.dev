# syntax=docker/dockerfile:1
FROM node:22-slim
WORKDIR /app

# Workspace deps install from the single root lockfile (hoisted to /app/node_modules).
# All workspace manifests must be present for `npm ci` to resolve the workspaces.
COPY package.json package-lock.json ./
COPY apps/api/package.json apps/api/package.json
COPY mcp/package.json mcp/package.json
RUN npm ci

# Copy source so the image runs standalone; in dev, Compose bind-mounts over apps/api.
COPY apps/api apps/api

WORKDIR /app/apps/api
EXPOSE 3000
# Env comes from Compose (env_file/environment); no --env-file here.
CMD ["npx", "tsx", "watch", "src/index.ts"]
